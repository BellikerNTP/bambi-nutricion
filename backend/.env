# Archivo de ejemplo de configuración para desarrollo local.
#
# IMPORTANTE:
# - El instalador de la app genera su propio .env con los datos
#   que introduce el usuario (usuario, contraseña y base de datos).
# - Este archivo solo se usa como plantilla / referencia cuando
#   ejecutas el backend desde VS Code.

# Connection string de Mongo Atlas de EJEMPLO (credenciales falsas):
# mongodb+srv://usuario:password@cluster0.abcde.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://usuario_falso:password_falso@cluster0.ejemplo.mongodb.net/?appName=bambiNutricion"

# Nombre de la base de datos de EJEMPLO
MONGODB_DB="nutricion_hogar_bambi_ejemplo"
